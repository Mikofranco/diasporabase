## Data Validation & Security

### 1. Input Validation (Client + Server)
```typescript
import { z } from 'zod'

// Define schema
const projectSchema = z.object({
  title: z.string().min(5, 'Title must be at least 5 characters'),
  description: z.string().min(20, 'Description must be at least 20 characters'),
  category: z.enum(['education', 'health', 'environment', 'community']),
  deadline: z.date().min(new Date(), 'Deadline must be in the future'),
})

// Validate on client
const handleSubmit = (data) => {
  const result = projectSchema.safeParse(data)
  if (!result.success) {
    setErrors(result.error.flatten().fieldErrors)
    return
  }
  // Submit valid data
}

// ALWAYS validate on server too
'use server'
export async function createProject(formData) {
  const parsed = projectSchema.safeParse(formData)
  if (!parsed.success) {
    return { error: 'Invalid data' }
  }
  // Process valid data
}
```

### 2. Authorization Checks
```typescript
// ✅ Check authorization before operations
export async function updateProject(projectId: string, updates: any) {
  const user = await getCurrentUser()
  if (!user) return { error: 'Unauthorized' }

  // Verify user owns this project
  const { data: project } = await supabase
    .from('projects')
    .select('agency_id')
    .eq('id', projectId)
    .single()

  if (project?.agency_id !== user.id) {
    return { error: 'You do not have permission to edit this project' }
  }

  // Proceed with update
}
```

