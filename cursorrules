## Common Bugs & Fixes

### 1. Authentication Bugs
```typescript
// ❌ BAD - Not handling auth properly
const user = await supabase.auth.getUser()
// Assumes user exists

// ✅ GOOD - Proper auth handling
const { data: { user }, error } = await supabase.auth.getUser()
if (error || !user) {
  redirect('/login')
}
```

### 2. State Management Bugs
```typescript
// ❌ BAD - Stale closures
useEffect(() => {
  const interval = setInterval(() => {
    console.log(count) // Always logs initial count
  }, 1000)
  return () => clearInterval(interval)
}, []) // Missing dependency

// ✅ GOOD - Proper dependencies
useEffect(() => {
  const interval = setInterval(() => {
    console.log(count)
  }, 1000)
  return () => clearInterval(interval)
}, [count])
```

### 3. Data Fetching Bugs
```typescript
// ❌ BAD - Not handling edge cases
const projects = data.filter(p => p.agency_id === user.id)

// ✅ GOOD - Handle null/undefined
const projects = data?.filter(p => p.agency_id === user?.id) ?? []
```

### 4. Form Submission Bugs
```typescript
// ❌ BAD - No loading state, no error handling
const handleSubmit = async (e) => {
  e.preventDefault()
  await createProject(formData)
}

// ✅ GOOD - Proper handling
const [isSubmitting, setIsSubmitting] = useState(false)
const [error, setError] = useState(null)

const handleSubmit = async (e) => {
  e.preventDefault()
  setIsSubmitting(true)
  setError(null)
  
  try {
    const result = await createProject(formData)
    if (result.error) {
      setError(result.error)
      return
    }
    // Success handling
    toast.success('Project created successfully!')
    router.push('/agency/projects')
  } catch (err) {
    setError('Something went wrong. Please try again.')
  } finally {
    setIsSubmitting(false)
  }
}
```

### 5. Memory Leak Fixes
```typescript
// ❌ BAD - Subscription not cleaned up
useEffect(() => {
  const subscription = supabase
    .channel('projects')
    .on('postgres_changes', { event: '*', schema: 'public', table: 'projects' }, 
      (payload) => setProjects(prev => [...prev, payload.new])
    )
    .subscribe()
}, [])

// ✅ GOOD - Cleanup subscription
useEffect(() => {
  const subscription = supabase
    .channel('projects')
    .on('postgres_changes', { event: '*', schema: 'public', table: 'projects' }, 
      (payload) => setProjects(prev => [...prev, payload.new])
    )
    .subscribe()

  return () => {
    subscription.unsubscribe()
  }
}, [])
```

